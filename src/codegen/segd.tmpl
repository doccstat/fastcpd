#include "fastcpd_template.h"
#include "fastcpd_xptr.h"
#include "families/{POLICY_HEADER}.h"

Rcpp::List fastcpd_{FAMILY_NAME}{FUNC_SUFFIX}_impl(
    arma::mat const& data, double const beta,
    int const segment_count,
    double const trim, double const momentum_coef,
    Rcpp::Nullable<Rcpp::Function> const& multiple_epochs_function,
    std::string const& family, double const epsilon, int const p,
    arma::colvec const& order, Rcpp::Nullable<Rcpp::Function> const& cost_pelt,
    Rcpp::Nullable<Rcpp::Function> const& cost_sen,
    Rcpp::Nullable<Rcpp::Function> const& cost_gradient,
    Rcpp::Nullable<Rcpp::Function> const& cost_hessian, bool const cp_only,
    double const vanilla_percentage, bool const warm_start,
    arma::colvec const& lower, arma::colvec const& upper,
    arma::colvec const& line_search, arma::mat const& variance_estimate,
    unsigned int const p_response, double const pruning_coef) {

  // Each of `cost_pelt`, `cost_sen`, `cost_gradient`, `cost_hessian` accepts
  // either an R closure (the long-standing path, wrapped via `Rcpp::Function`)
  // or a pre-compiled function pointer passed as an `externalptr` SEXP
  // (`Rcpp::XPtr`-wrapped, detected via `TYPEOF(...) == EXTPTRSXP` and
  // unwrapped by `fastcpd::xptr::Wrap*` -- see `fastcpd_xptr.h`). Both are
  // adapted to the same `std::function` signatures the solver expects, so no
  // other code needs to know which path produced them.
  std::function<double(arma::mat const&)> cost_pelt_;
  if (cost_pelt.isNotNull()) {
    SEXP const cost_pelt_sexp = cost_pelt.get();
    if (TYPEOF(cost_pelt_sexp) == EXTPTRSXP) {
      cost_pelt_ = fastcpd::xptr::WrapCostPelt(cost_pelt_sexp);
    } else {
      Rcpp::Function rfun(cost_pelt);
      cost_pelt_ = [rfun](arma::mat const& data) -> double {
        return Rcpp::as<double>(rfun(data));
      };
    }
  }
  std::function<double(arma::mat const&, arma::colvec const&)> cost_sen_;
  if (cost_sen.isNotNull()) {
    SEXP const cost_sen_sexp = cost_sen.get();
    if (TYPEOF(cost_sen_sexp) == EXTPTRSXP) {
      cost_sen_ = fastcpd::xptr::WrapCostSen(cost_sen_sexp);
    } else {
      Rcpp::Function rfun(cost_sen);
      cost_sen_ = [rfun](arma::mat const& data, arma::colvec const& theta) -> double {
        return Rcpp::as<double>(rfun(data, theta));
      };
    }
  }
  std::function<arma::colvec(arma::mat const&, arma::colvec const&)> cost_gradient_;
  if (cost_gradient.isNotNull()) {
    SEXP const cost_gradient_sexp = cost_gradient.get();
    if (TYPEOF(cost_gradient_sexp) == EXTPTRSXP) {
      cost_gradient_ = fastcpd::xptr::WrapCostGradient(cost_gradient_sexp);
    } else {
      Rcpp::Function rfun(cost_gradient);
      cost_gradient_ = [rfun](arma::mat const& data, arma::colvec const& theta) -> arma::colvec {
        return Rcpp::as<arma::colvec>(rfun(data, theta));
      };
    }
  }
  std::function<arma::mat(arma::mat const&, arma::colvec const&)> cost_hessian_;
  if (cost_hessian.isNotNull()) {
    SEXP const cost_hessian_sexp = cost_hessian.get();
    if (TYPEOF(cost_hessian_sexp) == EXTPTRSXP) {
      cost_hessian_ = fastcpd::xptr::WrapCostHessian(cost_hessian_sexp);
    } else {
      Rcpp::Function rfun(cost_hessian);
      cost_hessian_ = [rfun](arma::mat const& data, arma::colvec const& theta) -> arma::mat {
        return Rcpp::as<arma::mat>(rfun(data, theta));
      };
    }
  }
  std::function<unsigned int(unsigned int)> multiple_epochs_function_;
  if (multiple_epochs_function.isNotNull()) {
    Rcpp::Function rfun(multiple_epochs_function);
    multiple_epochs_function_ = [rfun](unsigned int i) -> unsigned int {
      return Rcpp::as<unsigned int>(rfun(i));
    };
  }

  fastcpd::classes::Fastcpd<fastcpd::families::{POLICY_CLASS}, {K_R_PROGRESS}, {K_VANILLA_ONLY}, fastcpd::classes::CostAdjustment::{K_COST_ADJUSTMENT}, {K_LINE_SEARCH}> fastcpd_class(
      beta, cost_pelt_, cost_sen_, cost_gradient_,
      cost_hessian_, cp_only, data, epsilon, family, multiple_epochs_function_,
      line_search, lower, momentum_coef, order, p, p_response, pruning_coef,
      segment_count, trim, upper, vanilla_percentage,
      variance_estimate, warm_start);

  auto result = fastcpd_class.Run();

  return Rcpp::List::create(Rcpp::Named("raw_cp_set") = std::get<0>(result),
                            Rcpp::Named("cp_set") = std::get<1>(result),
                            Rcpp::Named("cost_values") = std::get<2>(result),
                            Rcpp::Named("residual") = std::get<3>(result),
                            Rcpp::Named("thetas") = std::get<4>(result));
}
